# Fichier d'exemple pour les variables d'environnement (.env)
# Pour Render, ces variables se configurent dans l'onglet "Environment" du Dashboard.

# Clé secrète Flask (à modifier avec une chaîne aléatoire en production)
SECRET_KEY=une_cle_secrete_tres_complexe_pour_render

# Port utilisé par l'application (Render utilise souvent 10000 par défaut)
PORT=10000

# Environnement (production ou development)
FLASK_ENV=production
